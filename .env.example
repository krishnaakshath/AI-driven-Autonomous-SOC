# AI-Driven Autonomous SOC — Environment Configuration
# Copy this file to .env and fill in your values
# The app will load these values automatically

# ── Email Alerts (Gmail SMTP) ──
GMAIL_EMAIL=
GMAIL_PASSWORD=
GMAIL_RECIPIENT=

# ── Telegram Bot Alerts ──
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI / LLM ──
GEMINI_API_KEY=

# ── Threat Intelligence APIs ──
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# ── Supabase (Cloud Database) ──
SUPABASE_URL=
SUPABASE_KEY=

# ── Google OAuth (Optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8501
